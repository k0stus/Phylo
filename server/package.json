{
  "name": "phylo-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply phylo-db",
    "db:migrate:local": "wrangler d1 migrations apply phylo-db --local",
    "db:seed:local": "wrangler d1 execute phylo-db --local --file=./src/db/seed.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/zod-validator": "^0.2.2",
    "jose": "^5.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.65.1"
  }
}
